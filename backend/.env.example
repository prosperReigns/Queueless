APP_NAME=Queueless API
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_HEADERS=["Authorization","Content-Type","Accept","Origin"]
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]

JWT_SECRET_KEY=replace-with-a-secure-32-char-min-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=postgresql://user:password@localhost:5432/queueless
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYMENT_VERIFICATION_FALLBACK_DELAY_SECONDS=300

REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_ORDER_CREATE=10/minute
RATE_LIMIT_PAYMENTS=20/minute
RATE_LIMIT_PAYMENT_WEBHOOK=300/minute

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false

FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=

TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_SENDER_ID=Queueless
TERMII_CHANNEL=generic
TERMII_SEND_ORDER_READY_SMS=false
TERMII_TIMEOUT_SECONDS=10

ORDER_EXPIRY_MINUTES=10
